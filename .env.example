PORT=3000

MONGO_URI=mongodb://localhost:27018/futbol-tokens?replicaSet=rs0&directConnection=true

JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here

JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

FOOTBALL_DATA_TOKEN=your_football_data_token_here

SEED_ON_BOOT=true
SUPERUSER_EMAIL=superuser@futbol-tokens.local
SUPERUSER_PASSWORD=change-me-now

SCHEDULER_ENABLED=true
SCHEDULER_CRON_RECALC=0 3 * * 1
SCHEDULER_CRON_SYNC=0 4 * * 1

# Demo interactiva en /demo (poner false para deshabilitar el front y sus endpoints)
DEMO_ENABLED=true
